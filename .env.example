# .env.example - Template for PRP Pipeline configuration
# Copy this file to .env and fill in your values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your API credentials

# =============================================================================
# API AUTHENTICATION
# =============================================================================

# Your API authentication token
# This will be automatically mapped to ANTHROPIC_API_KEY
ANTHROPIC_AUTH_TOKEN=your-api-token-here

# Or set ANTHROPIC_API_KEY directly (AUTH_TOKEN takes precedence if both set)
# ANTHROPIC_API_KEY=your-api-key-here

# =============================================================================
# API ENDPOINT
# =============================================================================

# API endpoint (defaults to z.ai proxy)
# WARNING: Do NOT use https://api.anthropic.com (blocked by safeguards)
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Model selection is USER-CONFIGURABLE here, NOT hard-coded in source.
# The pipeline reads these env vars (via getModel()); if unset it falls back
# to sensible defaults baked into config/constants.ts, but you SHOULD set them
# explicitly so your chosen models are version-controlled and obvious.
#
# Values are provider-qualified ids as registered in the Pi model registry.
# Registry ids are LOWERCASE. To see what's available, run:
#   pi --list-models zai

# Model for Architect agent (highest quality, complex reasoning)
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2

# Model for Researcher/Coder agents (balanced, default)
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2

# Model for simple operations (fastest)
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5-turbo

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Request timeout in milliseconds (default: 60000)
# API_TIMEOUT_MS=300000

# =============================================================================
# CONCURRENCY CONFIGURATION
# =============================================================================

# Max concurrent research tasks for parallel PRP generation (1-10, default: 3)
# Higher values = faster PRP generation but more API usage
# Lower values = slower but respects rate limits
# RESEARCH_QUEUE_CONCURRENCY=3

# =============================================================================
# SECURITY NOTES
# =============================================================================

# NEVER commit this file to version control with actual API keys
# .env is listed in .gitignore
# Only commit .env.example as a template
